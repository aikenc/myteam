{
  "name": "myteam",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "myteam": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "node scripts/run-biome.mjs check --write --error-on-warnings . && npm run typecheck",
    "test": "node --test dist/tests/**/*.test.js",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/node": "22.19.19",
    "typescript": "5.9.3"
  }
}
